<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".annotations.AnnotationsFragment">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorPrimary"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Annotations"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <Button
                android:id="@+id/btn_save_annotation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a1a1a"
            android:scrollbars="none">

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:gravity="center_vertical">

                <!-- Bold -->
                <ImageButton android:id="@+id/btn_bold"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_bold"/>

                <!-- Italic -->
                <ImageButton android:id="@+id/btn_italic"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_italic"/>

                <!-- Underline -->
                <ImageButton android:id="@+id/btn_underline"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_underline"/>

                <!-- Strike -->
                <ImageButton android:id="@+id/btn_strike"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_strike1"/>

                <View style="@style/ToolbarDivider"/>

                <!-- Highlight yellow -->
                <ImageButton android:id="@+id/btn_highlight_yellow"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_highlight_yellow"/>

                <!-- Highlight green -->
                <ImageButton android:id="@+id/btn_highlight_green"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_highlight_green"/>

                <!-- Text red -->
                <ImageButton android:id="@+id/btn_text_red"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_text_red"/>

                <!-- Text blue -->
                <ImageButton android:id="@+id/btn_text_blue"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_text_blue"/>

                <View style="@style/ToolbarDivider"/>

                <!-- H1 -->
                <ImageButton android:id="@+id/btn_h1"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_h1"/>

                <!-- H2 -->
                <ImageButton android:id="@+id/btn_h2"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_h2"/>

                <!-- Blockquote -->
                <ImageButton android:id="@+id/btn_blockquote"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_blockquote"/>

                <!-- Bullet -->
                <ImageButton android:id="@+id/btn_bullets"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_bullets"/>

                <!-- Checkbox -->
                <ImageButton android:id="@+id/btn_checkbox"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_checkbox"/>

                <View style="@style/ToolbarDivider"/>

                <!-- Link -->
                <ImageButton android:id="@+id/btn_link"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_link"/>

                <!-- Youtube -->
                <ImageButton android:id="@+id/btn_youtube"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/appicon"/>

                <View style="@style/ToolbarDivider"/>

                <!-- Undo -->
                <ImageButton android:id="@+id/btn_undo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_undo"/>

                <!-- Redo -->
                <ImageButton android:id="@+id/btn_redo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/editor_icon_redo"/>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Rich Editor -->
        <jp.wasabeef.richeditor.RichEditor
            android:id="@+id/editor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>
</layout>