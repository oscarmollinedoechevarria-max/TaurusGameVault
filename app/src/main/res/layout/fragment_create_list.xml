<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".list.createlist.CreateListFragment">

        <!-- ========================================== -->
        <!-- HEADER -->
        <!-- ========================================== -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerLayout"
            android:layout_width="0dp"
            android:layout_height="56dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- FAB Go Back -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_go_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:contentDescription="@string/goBack"
                app:srcCompat="@drawable/chevronleft"
                app:backgroundTint="?attr/colorSecondary"
                app:tint="@android:color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <!-- Fragment Title -->
            <TextView
                android:id="@+id/tv_fragment_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create List"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ========================================== -->
        <!-- SCROLLABLE CONTENT -->
        <!-- ========================================== -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/headerLayout"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- ========================================== -->
                <!-- SECTION: BANNER IMAGE -->
                <!-- ========================================== -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/sectionBannerImage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="#F5F5F5"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <!-- Section Title -->
                    <TextView
                        android:id="@+id/sectionBannerImageTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Banner Image"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#333333"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <View
                        android:id="@+id/dividerBannerImage"
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="8dp"
                        android:background="#E0E0E0"
                        app:layout_constraintTop_toBottomOf="@id/sectionBannerImageTitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <!-- Image Container -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/bannerImageContainer"
                        android:layout_width="0dp"
                        android:layout_height="160dp"
                        android:layout_marginTop="12dp"
                        app:layout_constraintTop_toBottomOf="@id/dividerBannerImage"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <ImageView
                            android:id="@+id/imageView_list_banner"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:scaleType="centerCrop"
                            android:contentDescription="List banner image"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            tools:srcCompat="@tools:sample/backgrounds/scenic" />

                        <Button
                            android:id="@+id/selectBannerImageButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- ========================================== -->
                <!-- SECTION: BASIC INFO -->
                <!-- ========================================== -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/sectionBasicInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:layout_marginTop="16dp"
                    android:background="#F5F5F5"
                    app:layout_constraintTop_toBottomOf="@id/sectionBannerImage"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <!-- Section Title -->
                    <TextView
                        android:id="@+id/sectionBasicInfoTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Basic Info"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#333333"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <View
                        android:id="@+id/dividerBasicInfo"
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="8dp"
                        android:background="#E0E0E0"
                        app:layout_constraintTop_toBottomOf="@id/sectionBasicInfoTitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <!-- SUBSECTION: List Name -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/subsectionListName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:padding="12dp"
                        android:background="#FFFFFF"
                        app:layout_constraintTop_toBottomOf="@id/dividerBasicInfo"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <TextView
                            android:id="@+id/labelListName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="List Name*"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <EditText
                            android:id="@+id/textView_list_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:hint="Ex: My Favorite RPGs"
                            app:layout_constraintTop_toBottomOf="@id/labelListName"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- SUBSECTION: Description -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/subsectionDescription"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:padding="12dp"
                        android:background="#FFFFFF"
                        app:layout_constraintTop_toBottomOf="@id/subsectionListName"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <TextView
                            android:id="@+id/labelDescription"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Description"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <EditText
                            android:id="@+id/textView_list_description"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:minLines="3"
                            android:gravity="top"
                            android:hint="A personal collection of games I love..."
                            app:layout_constraintTop_toBottomOf="@id/labelDescription"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- ========================================== -->
                <!-- SECTION: GAMES -->
                <!-- ========================================== -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/sectionGames"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:layout_marginTop="16dp"
                    android:background="#F5F5F5"
                    app:layout_constraintTop_toBottomOf="@id/sectionBasicInfo"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <!-- Section Title -->
                    <TextView
                        android:id="@+id/sectionGamesTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Games"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#333333"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <View
                        android:id="@+id/dividerGames"
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="8dp"
                        android:background="#E0E0E0"
                        app:layout_constraintTop_toBottomOf="@id/sectionGamesTitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <!-- Games Info Container -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/gamesInfoContainer"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:padding="12dp"
                        android:background="#FFFFFF"
                        app:layout_constraintTop_toBottomOf="@id/dividerGames"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <TextView
                            android:id="@+id/labelGameCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Games"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/textView_game_count"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0 games"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            app:layout_constraintTop_toBottomOf="@id/labelGameCount"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- RecyclerView for Games -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerView_games"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:minHeight="100dp"
                        app:layout_constraintTop_toBottomOf="@id/gamesInfoContainer"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:listitem="@layout/item_game_picker"/>

                    <!-- Empty State -->
                    <LinearLayout
                        android:id="@+id/layout_empty"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:padding="24dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="#FFFFFF"
                        android:visibility="gone"
                        app:layout_constraintTop_toBottomOf="@id/gamesInfoContainer"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No games yet"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#333333" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Add your first game to this list"
                            android:textSize="14sp"
                            android:textColor="#666666" />
                    </LinearLayout>

                    <!-- Add Game Button -->
                    <Button
                        android:id="@+id/fab_add_game"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="+ Add Game"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/recyclerView_games"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- ========================================== -->
                <!-- SAVE BUTTON -->
                <!-- ========================================== -->
                <Button
                    android:id="@+id/saveListButton"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:text="Save List +"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    app:layout_constraintTop_toBottomOf="@id/sectionGames"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>