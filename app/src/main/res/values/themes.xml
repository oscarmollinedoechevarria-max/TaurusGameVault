<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.TaurusGameVault" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Fuente global -->
        <item name="android:fontFamily">@font/nunito</item>
        <item name="fontFamily">@font/nunito</item>

        <!-- Primary -->
        <item name="colorPrimary">@color/taurus_brown</item>
        <item name="colorOnPrimary">@color/light_on_primary</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/taurus_yellow</item>
        <item name="colorOnSecondary">@color/light_text_primary</item>

        <!-- Secondary Container -->
        <item name="colorSecondaryContainer">@color/color_secondary_container_light</item>
        <item name="colorOnSecondaryContainer">@color/color_on_secondary_container_light</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/color_background_light</item>
        <item name="colorOnBackground">@color/color_on_surface_light</item>

        <!-- Surface -->
        <item name="colorSurface">@color/color_surface_light</item>
        <item name="colorOnSurface">@color/color_on_surface_light</item>
        <item name="colorSurfaceVariant">@color/color_surface_variant_light</item>
        <item name="colorOnSurfaceVariant">@color/color_on_surface_variant_light</item>

        <!-- Error -->
        <item name="colorError">@color/color_error</item>
        <item name="colorOnError">@color/color_on_error</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/taurus_brown</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Toolbar -->
        <item name="toolbarStyle">@style/Widget.TaurusGameVault.Toolbar</item>
        <item name="actionBarTheme">@style/ThemeOverlay.TaurusGameVault.Toolbar</item>

    </style>

    <style name="Theme.TaurusGameVault" parent="Base.Theme.TaurusGameVault" />

    <style name="SplashTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/taurus_brown</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>